# ExacqMan credentials template (TOML).
#
# Copy this file to default.credentials next to exacqman.py, fill in your
# values, and keep default.credentials private (it is gitignored).
# One credentials file can be shared across multiple *.config files.
#
# default.config points at default.credentials so a fresh copy "just works"
# after you duplicate this file. Use alice.credentials / bob.credentials (or
# any path) and set credentials_file in [runtime] or pass --credentials on
# the CLI when you need per-environment files.

[auth]
username = ""
password = ""

# ExacqMan default config (TOML).
#
# Sections (TOML tables) are lowercase by convention. Cameras live under
# their server, so the same alias can be reused safely across different
# servers without ID collisions.
#
# All numeric values are real ints (no quotes); URLs and other strings
# require quotes. crop_dimensions are TOML arrays-of-arrays of ints:
# [[x, y], [width, height]].

[auth]
user = ""
password = ""

[settings]
timelapse_multiplier = 10
compression_level = "medium"
timezone = "US/Eastern"
font_weight = 2
# default_crop_dimensions applies to any camera that does not declare its
# own crop_dimensions override. Leave it out to disable the global default.
# default_crop_dimensions = [[0, 0], [1920, 1080]]

[runtime]
# Defaults used when CLI args aren't supplied. CLI args always win.
server = "ch"
camera_alias = "8"
filename = "test-video"
date = "2/6"
start_time = "6:30pm"
end_time = "6:35pm"
# Optional overlay text rendered below the timestamp (max 25 characters).
# caption = "Hello world"

[servers.ch]
url = "http://10.20.4.12"

[servers.ch.cameras.8]
id = 3483648

[servers.ch.cameras.9]
id = 3483904

[servers.ch.cameras.10]
id = 3484160

[servers.ch.cameras.11]
id = 3484416

[servers.ch.cameras.12]
id = 3484672

[servers.ch.cameras.13]
id = 3484928

[servers.ch.cameras.14]
id = 3485184

[servers.ch.cameras.15]
id = 3485440

[servers.home_server]
url = "http://127.0.0.1"

[servers.home_server.cameras.home_camera]
id = 1111111

# ExacqMan default config (TOML).
#
# Authentication lives in a separate credentials file. Copy sample.credentials
# to default.credentials next to exacqman.py and fill in [auth]. Or change
# settings.credentials_file below / pass --credentials on the CLI for another path.
#
# Sections (TOML tables) are lowercase by convention. Cameras live under
# their server, so the same alias can be reused safely across different
# servers without ID collisions.
#
# All numeric values are real ints (no quotes); URLs and other strings
# require quotes. crop_dimensions are TOML arrays-of-arrays of ints:
# [[x, y], [width, height]].

[settings]
credentials_file = "default.credentials"
timelapse_multiplier = 50
compression_level = "high"
timezone = "US/Eastern"
font_weight = 4
default_crop_dimensions = [[0, 0], [1920, 1080]]

[runtime]
server = "gpa"
camera_alias = "dock-6"
filename = "test-footage"
date = "2/6"
start_time = "6:30pm"
end_time = "7:05pm"
crop = true
caption = "Hello world"

[servers.ch]
url = "http://10.20.4.12"

[servers.gpa]
url = "http://10.60.4.10"

[servers.ch.cameras.dock-8]
id = 3483648

[servers.ch.cameras.dock-9]
id = 3483904

[servers.ch.cameras.dock-10]
id = 3484160

[servers.ch.cameras.dock-11]
id = 3484416

[servers.ch.cameras.dock-12]
id = 3484672

[servers.ch.cameras.dock-13]
id = 3484928

[servers.ch.cameras.dock-14]
id = 3485184

[servers.ch.cameras.dock-15]
id = 3485440

[servers.gpa.cameras.dock-5]
id = 3476992

[servers.gpa.cameras.dock-6]
id = 3477248
crop_dimensions = [[646, 20], [666, 1042]]

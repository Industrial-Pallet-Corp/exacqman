# ExacqMan default config (TOML).
#
# Authentication lives in a separate credentials file. Copy sample.credentials
# to default.credentials next to exacqman.py and fill in [auth]. Or change
# settings.credentials_file below / pass --credentials on the CLI for another path.
#
# Sections (TOML tables) are lowercase by convention. [settings] is reserved
# for program defaults; per-run values like server, camera, and time range come
# from CLI arguments. Every other top-level table is a server (e.g. [ch], [gpa])
# with a url. Cameras are sub-tables of their server ([<server>.<alias>]), so the
# same alias can be reused safely across different servers without ID
# collisions.
#
# All numeric values are real ints (no quotes); URLs and other strings
# require quotes. crop_dimensions are TOML arrays-of-arrays of ints:
# [[x, y], [width, height]].

[settings]
credentials_file = "default.credentials"
timelapse_multiplier = 50
compression_level = "high"
timezone = "America/Indiana/Indianapolis"
# Overlay stroke weight on a 1-5 scale (1 = thinnest, 5 = heaviest).
font_weight = 3
default_crop = true
default_crop_dimensions = [[0, 0], [1920, 1080]]


[ch]
url = "http://10.20.4.12"

[gpa]
url = "http://10.60.4.10"

[mit]
url = "http://10.40.4.14"


[ch.dock-8]
